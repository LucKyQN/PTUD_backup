package DAO;

import Entity.NhanVien;
import connectDatabase.ConnectDB;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;

public class NhanVienDAO {

    public NhanVien dangNhap(String tenDangNhap, String matKhau) {
        NhanVien nv = null;

        String sql = "SELECT * FROM nhan_vien " +
                     "WHERE ten_dang_nhap = ? AND mat_khau = ? AND trang_thai = 1";

        try {
            Connection con = ConnectDB.getInstance().getConnection();
            PreparedStatement stmt = con.prepareStatement(sql);
            stmt.setString(1, tenDangNhap);
            stmt.setString(2, matKhau);

            ResultSet rs = stmt.executeQuery();
            if (rs.next()) {
                nv = new NhanVien();
                nv.setMaNV(rs.getString("ma_nv"));
                nv.setHoTenNV(rs.getString("ho_ten_nv"));
                nv.setSoDienThoai(rs.getString("so_dien_thoai"));
                nv.setHeSoLuong(rs.getDouble("he_so_luong"));
                nv.setGioiTinh(rs.getString("gioi_tinh"));
                nv.setDiaChi(rs.getString("dia_chi"));
                nv.setCaLam(rs.getString("ca_lam"));
                nv.setKhuVucQuanLy(rs.getString("khu_vuc_quan_ly"));
                nv.setKhuVucPhucVu(rs.getString("khu_vuc_phuc_vu"));
                nv.setKhuVucTiepTan(rs.getString("khu_vuc_tiep_tan"));
                nv.setTenDangNhap(rs.getString("ten_dang_nhap"));
                nv.setMatKhau(rs.getString("mat_khau"));
                nv.setVaiTro(rs.getString("vai_tro"));
                nv.setTrangThai(rs.getBoolean("trang_thai"));
            }

            rs.close();
            stmt.close();
        } catch (Exception e) {
            e.printStackTrace();
        }

        return nv;
    }
}