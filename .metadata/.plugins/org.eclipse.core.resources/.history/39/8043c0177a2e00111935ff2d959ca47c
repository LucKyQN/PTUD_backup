	private void initUI() {
		setTitle("Nhà Hàng Ngói Đỏ - Phân hệ: " + userRole);
		setSize(1440, 860);
		setLocationRelativeTo(null);
		setDefaultCloseOperation(EXIT_ON_CLOSE);

