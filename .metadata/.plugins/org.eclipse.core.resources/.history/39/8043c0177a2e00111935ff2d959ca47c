	// CONSTRUCTOR: Bắt buộc truyền Vai trò và Tên nhân viên vào
	public FrmMain_SoDoBan(String userRole, String maNV, String tenNV) {
		this.userRole = userRole;
		this.maNV = maNV;
		this.tenNV = tenNV;
		
		initUI();
