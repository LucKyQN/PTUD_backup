		root.setBackground(BG_MAIN);
		root.add(createTopBar(), BorderLayout.NORTH);

		JPanel centerWrap = new JPanel(new BorderLayout());
		centerWrap.setOpaque(false);
		centerWrap.add(createTabs(), BorderLayout.NORTH);
		centerWrap.add(createMapArea(), BorderLayout.CENTER);

		root.add(centerWrap, BorderLayout.CENTER);
		
		// Khởi tạo cột phải
		rightSidebar = createRightSidebar();
		root.add(rightSidebar, BorderLayout.EAST);
		
		// LOGIC ẨN HIỆN CỘT PHẢI THEO ROLE
		if (!userRole.equalsIgnoreCase("Lễ tân")) {
		    // Phục vụ / Thu ngân không cần xem danh sách đặt bàn
		    rightSidebar.setVisible(false);
		} else {
		    loadDanhSachDatCho();
		}
		
		setContentPane(root);
	}

