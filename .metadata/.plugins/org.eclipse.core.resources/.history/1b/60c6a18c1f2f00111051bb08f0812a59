package Model;

public class NhanVienModel {
	public String maNV; // Mã nhân viên (Khóa chính)
	public String tenNV; // Tên đầy đủ
	public String chucVu; // Ví dụ: Lễ tân, Thu ngân, Quản lý
	public String taiKhoan; // Tên đăng nhập
	public String matKhau; // Mật khẩu (thường dùng để check login)

	// Constructor mặc định
	public NhanVienModel() {
	}

	// Constructor đầy đủ (tùy chọn)
	public NhanVienModel(String maNV, String tenNV, String chucVu) {
		this.maNV = maNV;
		this.tenNV = tenNV;
		this.chucVu = chucVu;
	}
}