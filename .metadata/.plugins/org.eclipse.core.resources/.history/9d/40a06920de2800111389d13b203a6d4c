    // ============================================================
    //  KHỞI TẠO UI
    // ============================================================
    private void initUI() {
        setTitle("Thanh toán & Hóa đơn - Nhà Hàng Ngói Đỏ");
        setSize(1440, 860);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);

