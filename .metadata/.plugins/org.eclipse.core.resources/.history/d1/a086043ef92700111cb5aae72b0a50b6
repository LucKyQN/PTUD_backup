package Entity;
import java.util.Objects;
public class DanhMuc {
    private String maDM;
    private String tenDM;

    public DanhMuc() {}

    public String getMaDM() {
        return maDM;
    }

    public void setMaDM(String maDM) {
        this.maDM = maDM;
    }

    public String getTenDM() {
        return tenDM;
    }

    public void setTenDM(String tenDM) {
        this.tenDM = tenDM;
    }
}