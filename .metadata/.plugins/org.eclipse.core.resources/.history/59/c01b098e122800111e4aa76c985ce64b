class BarChartPanel extends JPanel {
    private final String[] labels;
    private final double[] values;
    private final Color barColor = new Color(244, 63, 63);

    public BarChartPanel(String[] labels, double[] values) {
        this.labels = labels;
        this.values = values;
        setOpaque(false);
        setPreferredSize(new Dimension(500, 260));
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);

        if (labels == null || values == null || labels.length == 0) return;

        Graphics2D g2 = (Graphics2D) g.create();
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        int left = 50;
        int right = 20;
        int top = 15;
        int bottom = 35;
        int chartWidth = getWidth() - left - right;
        int chartHeight = getHeight() - top - bottom;

        g2.setColor(new Color(235, 238, 242));
        for (int i = 0; i <= 4; i++) {
            int y = top + i * chartHeight / 4;
            g2.drawLine(left, y, left + chartWidth, y);
        }

        g2.setColor(new Color(180, 180, 180));
        g2.drawLine(left, top + chartHeight, left + chartWidth, top + chartHeight);

        double max = 20.0;
        int n = values.length;
        int gap = 18;
        int barWidth = (chartWidth - gap * (n + 1)) / n;

        for (int i = 0; i < n; i++) {
            int x = left + gap + i * (barWidth + gap);
            int barHeight = (int) (values[i] / max * chartHeight);
            int y = top + chartHeight - barHeight;

            g2.setColor(barColor);
            g2.fillRect(x, y, barWidth, barHeight);

            g2.setColor(new Color(100, 100, 100));
            g2.setFont(new Font("Segoe UI", Font.PLAIN, 12));
            FontMetrics fm = g2.getFontMetrics();
            int tx = x + (barWidth - fm.stringWidth(labels[i])) / 2;
            g2.drawString(labels[i], tx, top + chartHeight + 18);
        }

        String[] yLabels = {"20 T đ", "15 T đ", "10 T đ", "5 T đ", "0 đ"};
        g2.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        g2.setColor(new Color(120, 120, 120));
        for (int i = 0; i < yLabels.length; i++) {
            int y = top + i * chartHeight / 4;
            g2.drawString(yLabels[i], 5, y + 5);
        }

        g2.dispose();
    }
}

class PieChartPanel extends JPanel {
    private final Map<String, Double> data;
    private final Color[] colors = {
            new Color(244, 63, 94),
            new Color(249, 115, 22),
            new Color(245, 158, 11),
            new Color(234, 179, 8)
    };

    public PieChartPanel(Map<String, Double> data) {
        this.data = data;
        setOpaque(false);
        setPreferredSize(new Dimension(500, 260));
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);

        if (data == null || data.isEmpty()) return;

        Graphics2D g2 = (Graphics2D) g.create();
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        int chartSize = 160;
        int cx = getWidth() / 2;
        int cy = getHeight() / 2 + 10;
        int x = cx - chartSize / 2;
        int y = cy - chartSize / 2;

        double total = 0;
        for (double v : data.values()) total += v;

        int startAngle = 0;
        int i = 0;
        for (Map.Entry<String, Double> entry : data.entrySet()) {
            int arcAngle = (int) Math.round(entry.getValue() / total * 360);
            g2.setColor(colors[i % colors.length]);
            g2.fillArc(x, y, chartSize, chartSize, startAngle, arcAngle);
            startAngle += arcAngle;
            i++;
        }

        i = 0;
        int legendX = 40;
        int legendY = 35;
        g2.setFont(new Font("Segoe UI", Font.PLAIN, 13));

        for (Map.Entry<String, Double> entry : data.entrySet()) {
            g2.setColor(colors[i % colors.length]);
            g2.fillRoundRect(legendX, legendY + i * 28, 14, 14, 6, 6);
            g2.setColor(new Color(90, 90, 90));
            g2.drawString(entry.getKey(), legendX + 22, legendY + 12 + i * 28);
            i++;
        }

        g2.dispose();
    }
}

class StatusBadgeRenderer extends DefaultTableCellRenderer {
    private Color badgeBg = new Color(220, 252, 231);
    private Color badgeFg = new Color(22, 163, 74);

    public StatusBadgeRenderer() {
        setHorizontalAlignment(SwingConstants.CENTER);
        setBorder(new EmptyBorder(6, 12, 6, 12));
        setFont(new Font("Segoe UI", Font.BOLD, 13));
    }

    @Override
    public Component getTableCellRendererComponent(JTable table, Object value, boolean isSelected,
                                                   boolean hasFocus, int row, int column) {
        super.getTableCellRendererComponent(table, value, false, false, row, column);

        String text = value == null ? "" : value.toString();
        setText(text);

        if ("Đang mở".equalsIgnoreCase(text)) {
            badgeBg = new Color(220, 252, 231);
            badgeFg = new Color(22, 163, 74);
        } else {
            badgeBg = new Color(239, 241, 245);
            badgeFg = new Color(100, 116, 139);
        }

        setForeground(badgeFg);
        setBackground(new Color(0, 0, 0, 0));
        return this;
    }

    @Override
    protected void paintComponent(Graphics g) {
        Graphics2D g2 = (Graphics2D) g.create();
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        g2.setColor(badgeBg);
        g2.fillRoundRect(10, 8, getWidth() - 20, getHeight() - 16, 20, 20);
        g2.dispose();

        super.paintComponent(g);
    }

    @Override
    public boolean isOpaque() {
        return false;
    }
}

class DifferenceRenderer extends DefaultTableCellRenderer {
    public DifferenceRenderer() {
        setHorizontalAlignment(SwingConstants.LEFT);
        setBorder(new EmptyBorder(0, 10, 0, 10));
        setFont(new Font("Segoe UI", Font.BOLD, 13));
    }

    @Override
    public Component getTableCellRendererComponent(JTable table, Object value, boolean isSelected,
                                                   boolean hasFocus, int row, int column) {
        super.getTableCellRendererComponent(table, value, false, false, row, column);

        String text = value == null ? "" : value.toString();
        setText(text);

        if (text.startsWith("+")) {
            setForeground(new Color(249, 115, 22));
        } else if ("0đ".equals(text)) {
            setForeground(new Color(22, 163, 74));
        } else {
            setForeground(new Color(100, 116, 139));
        }

        return this;
    }
}